// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  role          UserRole @default(CUSTOMER)
  avatar        String?
  password      String?
  phone         String?  @unique
  address       String?
  walletBalance Decimal  @default(0) @db.Decimal(14, 2)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  orders    Order[]
  payments  Payment[]
  dataUsage DataUsage[]

  // Developer integrations
  apiKeys  APIKey[]
  webhooks WebhookSubscription[]

  // Password reset
  passwordResets PasswordReset[]

  // Vouchers
  vouchers         Voucher[]
  voucherPurchases VoucherPurchase[]

  @@map("users")
}

model DataPlan {
  id              String   @id @default(cuid())
  name            String
  description     String?
  price           Decimal  @db.Decimal(10, 2)
  priceCustomer   Decimal  @default(0) @db.Decimal(10, 2)
  priceAgent      Decimal  @default(0) @db.Decimal(10, 2)
  priceWholesaler Decimal  @default(0) @db.Decimal(10, 2)
  priceDealer     Decimal  @default(0) @db.Decimal(10, 2)
  dataAmount      Int // in MB
  validity        Int // in days
  network         String // MTN, Airtel, Telecel
  /// Upstream plan id for providers that require a fixed SKU per bundle (e.g. DataDash GH `plan_id`).
  providerPlanId  String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  orders Order[]

  @@map("data_plans")
}

model Network {
  id                 String   @id @default(cuid())
  name               String   @unique
  isActive           Boolean  @default(true)
  // Provider config — set these to enable automatic fulfillment.
  // Leave apiProvider null (or set to "MANUAL") to route to admin queue.
  apiProvider        String?  // e.g. "DATAHUBGH" | "DATADASHGH" | "DATAWAVEGH" | "HUBNETGH"
  apiKey             String?  // provider API key
  baseUrl            String?  @default("https://user.datahubgh.com/api")
  providerNetworkKey String?  // key the provider uses for this network, e.g. "YELLO", "AT_PREMIUM"
  createdAt          DateTime @default(now())
  updatedAt          DateTime @default(now()) @updatedAt

  @@map("networks")
}

model Order {
  id                String      @id @default(cuid())
  orderNumber       Int?        @unique // Sequential order number starting from 1
  userId            String
  planId            String
  status            OrderStatus @default(PENDING)
  amount            Decimal     @db.Decimal(10, 2)
  phone             String
  reference         String      @unique
  providerReference String? // Reference from VTU provider (e.g., DataHubGH)
  isManual          Boolean     @default(false) // True if order is processed manually (not via API)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan     DataPlan   @relation(fields: [planId], references: [id])
  payments Payment[]
  logs     OrderLog[]

  @@index([userId])
  @@index([status])
  @@index([reference])
  @@index([createdAt])
  @@map("orders")
}

model Payment {
  id        String        @id @default(cuid())
  orderId   String
  userId    String
  amount    Decimal       @db.Decimal(10, 2)
  status    PaymentStatus @default(PENDING)
  method    String // paystack, bank_transfer, etc.
  reference String        @unique
  gateway   String? // paystack reference
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // Relations
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@index([reference])
  @@map("payments")
}

model DataUsage {
  id       String   @id @default(cuid())
  userId   String
  phone    String
  dataUsed Int // in MB
  planName String
  network  String
  usedAt   DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([usedAt])
  @@map("data_usage")
}

model Transaction {
  id          String            @id @default(cuid())
  userId      String
  type        TransactionType
  amount      Decimal           @db.Decimal(10, 2)
  description String
  reference   String            @unique
  status      TransactionStatus @default(PENDING)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([reference])
  @@index([createdAt])
  @@map("transactions")
}

model APIKey {
  id           String    @id @default(cuid())
  userId       String
  name         String
  keyHash      String // hashed API key
  encryptedKey String? // encrypted full API key for viewing
  prefix       String // public prefix for display
  lastFour     String // last 4 for display
  revoked      Boolean   @default(false)
  lastUsedAt   DateTime?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("api_keys")
}

model WebhookSubscription {
  id        String   @id @default(cuid())
  userId    String
  url       String
  secret    String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("webhook_subscriptions")
}

model VtuSource {
  id        String   @id @default(cuid())
  name      String
  provider  String // e.g., DATAHUBGH
  baseUrl   String
  apiKey    String
  isDefault Boolean  @default(false)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  networkApiSettings NetworkApiSetting[]

  @@map("vtu_sources")
}

model NetworkApiSetting {
  id          String   @id @default(cuid())
  networkName String   @unique // Network name from DataPlan (e.g., "MTN", "AT BIGTIME", "TELECEL")
  vtuKey      String // VTU provider key (e.g., "YELLO", "AT_BIGTIME", "TELECEL")
  vtuSourceId String? // Optional: link to VTU source. If null, use manual processing
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  vtuSource VtuSource? @relation(fields: [vtuSourceId], references: [id], onDelete: SetNull)

  @@index([networkName])
  @@map("network_api_settings")
}

model PasswordReset {
  id         String   @id @default(cuid())
  userId     String
  method     String // "email" or "phone"
  identifier String // email address or phone number
  code       String // 6-digit reset code
  expiresAt  DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([identifier, method])
  @@map("password_resets")
}

model Voucher {
  id        String      @id @default(cuid())
  code      String      @unique // Unique voucher code (auto-generated or uploaded)
  pin       String? // PIN from uploaded voucher
  serial    String? // Serial number from uploaded voucher
  type      VoucherType // BECE or WASSCE
  price     Decimal     @db.Decimal(10, 2) // Price of the voucher
  isUsed    Boolean     @default(false)
  isActive  Boolean     @default(true)
  isSold    Boolean     @default(false) // Mark if voucher is sold
  userId    String? // User who purchased/owns the voucher
  usedAt    DateTime? // When the voucher was used
  expiresAt DateTime? // Optional expiration date
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // Relations
  user      User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  purchases VoucherPurchase[]

  @@index([userId])
  @@index([type])
  @@index([code])
  @@index([pin])
  @@index([serial])
  @@map("vouchers")
}

model VoucherPurchase {
  id          String      @id @default(cuid())
  userId      String
  voucherId   String
  amount      Decimal     @db.Decimal(10, 2)
  status      OrderStatus @default(PENDING)
  reference   String      @unique
  method      String // wallet, paystack, etc.
  phoneNumber String? // Phone number where voucher was sent
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  voucher Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([reference])
  @@map("voucher_purchases")
}

model VoucherPricing {
  id        String      @id @default(cuid())
  type      VoucherType @unique // BECE or WASSCE
  price     Decimal     @db.Decimal(10, 2) // Default price for this voucher type
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([type])
  @@map("voucher_pricing")
}

enum UserRole {
  CUSTOMER
  AGENT
  WHOLESALER
  DEALER
  ADMIN
}

enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum TransactionType {
  PURCHASE
  REFUND
  COMMISSION
  BONUS
  TOPUP
  DEBIT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

enum VoucherType {
  BECE
  WASSCE
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

model OrderLog {
  id        String   @id @default(cuid())
  orderId   String
  level     LogLevel @default(INFO)
  message   String
  metadata  String? // JSON string for additional data
  createdAt DateTime @default(now())

  // Relations
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
  @@index([level])
  @@map("order_logs")
}

enum LogLevel {
  INFO
  WARNING
  ERROR
  SUCCESS
}
